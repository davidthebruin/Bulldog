<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Esk & Mo's Birthday Celebration!</title>

<style>
body{
font-family: Arial, sans-serif;
background: linear-gradient(#ffb6f0,#ffe8a3);
text-align:center;
margin:0;
}

h1{
font-size:48px;
color:#ff0066;
margin-top:20px;
}

h2{
color:#333;
}

.banner{
font-size:26px;
background:#fff;
padding:15px;
margin:20px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.2);
}

.gallery{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:20px;
padding:20px;
}

.gallery img{
width:220px;
height:160px;
object-fit:cover;
border-radius:12px;
box-shadow:0 5px 10px rgba(0,0,0,0.2);
}

#gameArea{
position:relative;
height:400px;
background:white;
margin:20px auto;
width:80%;
border-radius:12px;
overflow:hidden;
box-shadow:0 0 10px rgba(0,0,0,0.3);
}

.balloon{
position:absolute;
font-size:40px;
cursor:pointer;
}

#score{
font-size:24px;
margin-top:10px;
}

button{
padding:12px 20px;
font-size:18px;
border:none;
border-radius:8px;
background:#ff4da6;
color:white;
cursor:pointer;
}

button:hover{
background:#ff1a8c;
}

footer{
margin-top:40px;
padding:20px;
font-size:18px;
}
</style>
</head>

<body>

<h1>🎉 Esk & Mo's Birthday Bash! 🎉</h1>

<div class="banner">
Welcome to the ultimate birthday party for **Esk and Mo!**  
Eat cake, pop balloons, and celebrate! 🎂🎈
</div>

<h2>Party Gallery</h2>

<div class="gallery">

<img src="https://images.unsplash.com/photo-1535141192574-5d4897c12636">
<img src="https://images.unsplash.com/photo-1464349153735-7db50ed83c84">
<img src="https://images.unsplash.com/photo-1527529482837-4698179dc6ce">
<img src="https://images.unsplash.com/photo-1551024601-bec78aea704b">
<img src="https://images.unsplash.com/photo-1513151233558-d860c5398176">
<img src="https://images.unsplash.com/photo-1602631985686-1bb0e6a8696b">

</div>

<h2>🎮 Balloon Pop Game</h2>

<p>Click the balloons before they float away!</p>

<div id="score">Score: 0</div>
<br>
<button onclick="startGame()">Start Game</button>

<div id="gameArea"></div>

<footer>
🎂 Happy Birthday Esk & Mo! 🎂  
Have the most fun birthday ever!
</footer>

<script>

let score = 0
let gameRunning = false

function startGame(){
score = 0
gameRunning = true
document.getElementById("score").innerText = "Score: 0"
spawnBalloon()
}

function spawnBalloon(){

if(!gameRunning) return

let balloon = document.createElement("div")
balloon.className = "balloon"
balloon.innerHTML = "🎈"

let gameArea = document.getElementById("gameArea")

balloon.style.left = Math.random() * (gameArea.clientWidth - 40) + "px"
balloon.style.bottom = "0px"

gameArea.appendChild(balloon)

let position = 0

let rise = setInterval(function(){

position += 2
balloon.style.bottom = position + "px"

if(position > gameArea.clientHeight){
balloon.remove()
clearInterval(rise)
}

},20)

balloon.onclick = function(){
score++
document.getElementById("score").innerText = "Score: " + score
balloon.remove()
clearInterval(rise)
}

setTimeout(spawnBalloon,1000)

}

</script>

</body>
</html>
